{
  "print": {
    "prefix": "print",
    "body": "print($0)"
  },

  "pvi": {
    "prefix": "pvi",
    "body": ["print(vim.inspect(${0}))"]
  },
  "p": {
    "prefix": "p",
    "body": ["print(${0})"]
  },

  "vi": {
    "prefix": "vi",
    "body": ["vim.inspect(${0})"]
  },

   "If Else Statement": {
    "prefix": "ife",
    "body": [
      "if ${1:condition} then",
      "  ${2}",
      "else",
      "  ${0}",
      "end"
    ],
    "description": "If else statement"
  },

  "For Loop": {
    "prefix": "for",
    "body": [
      "for ${1:i} = ${2:1}, ${3:n} do",
      "  ${0}",
      "end"
    ],
    "description": "Numeric for loop"
  },

  "For Pairs Loop": {
    "prefix": "pairs",
    "body": [
      "for ${1:key}, ${2:value} in pairs(${3:table}) do",
      "  ${0}",
      "end"
    ],
    "description": "Loop through table with pairs"
  },

  "For Ipairs Loop": {
    "prefix": "ipairs",
    "body": [
      "for ${1:index}, ${2:value} in ipairs(${3:table}) do",
      "  ${0}",
      "end"
    ],
    "description": "Loop through array with ipairs"
  },

  "Protected Call": {
    "prefix": "pcall",
    "body": [
      "local ok, ${1:name} = pcall()"
    ],
    "description": "pcall wrapper"
  },

  "mod": {
    "prefix": "mod",
    "body": [
      "local M = {}",
      "",
      "M.config = function()",
      " return $0",
      "end",
      "",
      "return M"
    ]
  },

  "keymap": {
    "prefix": "keymap",
    "body": [
      "vim.keymap.set(\"${1:mode}\", \"${2:keys}\", function()",
      "  ${0}",
      "end, { buffer = event.buffer, desc = \"${3:description}\" })"
    ]
  },

  "callback": {
    "prefix": "callback",
    "body": [
      "local function callback()",
      "  return {$0}",
      "end",
      "",
      "return callback"
    ],
    "description": "Create a local callback function and return it"
  }

}
